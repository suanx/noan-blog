# ===========================================
# Noan Blog - 环境变量示例
# 复制此文件为 .env.local 并填入实际值
# ===========================================

# --- Turso 数据库（必需）---
TURSO_DATABASE_URL=libsql://your-db-url.turso.io
TURSO_AUTH_TOKEN=d1234567890abcdef

# --- 认证（必需）---
JWT_SECRET=your-very-long-and-random-jwt-secret-key-here
ADMIN_TOKEN=your-admin-token-here

# --- 网站配置 ---
NEXT_PUBLIC_SITE_URL=https://your-blog-domain.com

# --- Webhook（可选）---
WEBHOOK_URLS=https://your-webhook.com/notify

# --- AI 辅助（可选）---
AI_API_KEY=sk-your-ai-api-key
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-3.5-turbo
